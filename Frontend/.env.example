# Frontend Environment Variables Template

# Create a .env file in the Frontend directory or add these to Vercel environment variables.

# The URL of your deployed Railway backend
VITE_API_BASE_URL=https://your-backend-name.up.railway.app/api

# If you use Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Mapbox
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token

# Razorpay (Public Key)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
