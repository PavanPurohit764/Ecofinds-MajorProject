# Backend Environment Variables Template

# Create a .env file in the Backend directory and fill in these values for production.
# On Railway, add these as Variables in your service settings.

MONGODB_URI=your_mongodb_atlas_connection_string
PORT=5001
NODE_ENV=production

# JWT Secrets (Generate long random strings)
JWT_SECRET=your_jwt_secret
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
ADMIN_JWT_SECRET=your_admin_jwt_secret

# Expirations
JWT_EXPIRES_IN=1d
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=3d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email (Nodemailer)
EMAIL_USER=your_email
EMAIL_PASS=your_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true

# Admin Defaults
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_admin_password

# Frontend URL (Crucial for CORS)
FRONTEND_URL=https://your-app-name.vercel.app
